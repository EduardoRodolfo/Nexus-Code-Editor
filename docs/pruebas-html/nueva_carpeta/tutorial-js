        .card {
            border: 2px solid #3498db;
            border-radius: 10px;
            padding: 20px;
            margin: 10px;
            background-color: #f0f8ff;
        }
        .highlight {
            background-color: #fff3cd;
            font-weight: bold;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;div id="container"&gt;&lt;/div&gt;

    &lt;script&gt;
        // 1. Crear elementos
        const card = document.createElement('div');
        const title = document.createElement('h2');
        const content = document.createElement('p');
        const button = document.createElement('button');
        
        // 2. Configurar atributos y propiedades
        card.className = 'card';
        card.id = 'card-1';
        
        title.textContent = 'Hola Mundo';
        title.setAttribute('data-info', 'ejemplo-dom');
        
        content.innerHTML = 'Este es un &lt;strong&gt;elemento creado&lt;/strong&gt; dinamicamente';
        
        button.textContent = 'Haz clic';
        button.classList.add('highlight');
        
