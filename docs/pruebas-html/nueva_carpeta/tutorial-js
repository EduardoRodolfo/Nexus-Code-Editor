            width: calc(100% - 20px);
            height: 50px;
            background: #333;
            color: white;
            padding: 10px;
            border-radius: 8px;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body id="body"&gt;
    &lt;h2&gt;Teclado Virtual en Movil&lt;/h2&gt;
    &lt;div id="areaTeclado"&gt;
        👉 Toca aqui para activar el teclado
    &lt;/div&gt;
    
    &lt;div class="console" id="consolaContainer"&gt;
        &lt;strong&gt;Consola:&lt;/strong&gt; &lt;span id="estadoTeclado"&gt;(Teclado inactivo - Toca aqui)&lt;/span&gt;
        &lt;div id="consola"&gt;&lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- Campo para activar teclado --&gt;
    &lt;input type="text" id="inputTeclado" placeholder="Escribe aqui..." /&gt;

    &lt;script&gt;
        // Elementos DOM
        const body = document.getElementById('body');
        const areaTeclado = document.getElementById('areaTeclado');
        const consolaContainer = document.getElementById('consolaContainer');
        const consola = document.getElementById('consola');
        const inputTeclado = document.getElementById('inputTeclado');
        const estadoTeclado = document.getElementById('estadoTeclado');
        
        // Función para registrar en la consola visual
        function logConsola(tipo, mensaje) {
            const linea = document.createElement('div');
            const hora = new Date().toLocaleTimeString();
            
            // Crear etiqueta de evento con color
            const tag = document.createElement('span');
            tag.className = `event-tag ${tipo}`;
            tag.textContent = tipo.toUpperCase();
            
            linea.appendChild(tag);
            linea.appendChild(document.createTextNode(` [${hora}]: ${mensaje}`));
            consola.appendChild(linea);
            consola.scrollTop = consola.scrollHeight; // Auto-scroll
        }

        // Función para activar el teclado
        function activarTeclado() {
            // Enfocar el input después de un pequeño retraso
            setTimeout(() => {
                inputTeclado.focus();
                inputTeclado.select();
            }, 50);
            
            body.classList.add('teclado-abierto');
            consolaContainer.classList.add('console-expanded');
            estadoTeclado.textContent = '(ESCRIBE - Teclado activado)';
            estadoTeclado.style.color = '#4cc9f0';
            areaTeclado.classList.add('teclado-activo');
            logConsola('teclado', 'Teclado virtual activado');
        }

        // Evento para activar teclado
        consolaContainer.addEventListener('touchend', (e) => {
            e.preventDefault();
            activarTeclado();
        });
        
        areaTeclado.addEventListener('touchend', (e) => {
            e.preventDefault();
            activarTeclado();
        });

        // Eventos de teclado
        inputTeclado.addEventListener('keydown', (evento) => {
            let msg = `Tecla: &lt;span class="key-info"&gt;${evento.key}&lt;/span&gt; `;
            msg += `Código: &lt;span class="key-info"&gt;${evento.code}&lt;/span&gt; `;
            msg += `Alt: ${evento.altKey} | Ctrl: ${evento.ctrlKey} | Shift: ${evento.shiftKey}`;
            logConsola('keydown', msg);
            
            // Prevenir acciones por defecto para teclas especiales
            if(['Space', 'ArrowUp', 'ArrowDown', 'Enter'].includes(evento.code)) {
                evento.preventDefault();
            }
        });

        inputTeclado.addEventListener('keyup', (evento) => {
            logConsola('keyup', `Tecla liberada: ${evento.key}`);
        });

        inputTeclado.addEventListener('keypress', (evento) => {
            logConsola('keypress', `Carácter: ${evento.key} (CharCode: ${evento.charCode})`);
        });

        // Desactivar teclado al tocar fuera
        document.addEventListener('touchend', (evento) => {
            if (!consolaContainer.contains(evento.target) && 
                !areaTeclado.contains(evento.target) && 
                evento.target !== inputTeclado) {
                
                inputTeclado.blur();
                body.classList.remove('teclado-abierto');
                consolaContainer.classList.remove('console-expanded');
                estadoTeclado.textContent = '(Teclado inactivo - Toca para activar)';
                estadoTeclado.style.color = '#d4d4d4';
                areaTeclado.classList.remove('teclado-activo');
            }
        });

        // Mensaje inicial
        logConsola('system', 'Toca el area azul o la consola para activar el teclado');
        logConsola('system', 'Prueba con teclas especiales: Espacio, Flechas, Enter');
        logConsola('system', 'El teclado se expandira automaticamente en dispositivos moviles');
        
        // Configuración inicial del campo de entrada
        inputTeclado.value = "";
        inputTeclado.blur();
    &lt;/script&gt;
