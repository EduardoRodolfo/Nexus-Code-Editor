  <pre><code>// =============================================
// EJEMPLOS CORREGIDOS DE EXPONENCIACIÓN EN JAVASCRIPT
// =============================================

// 1. Raíz cuadrada de número negativo (NaN)
console.log((-4) ** 0.5);  // Output: NaN
/* 
Explicación: 
- JavaScript no puede calcular raíces pares de números negativos
- (0.5 = 1/2 equivale a raíz cuadrada)
*/

// 2. PRECEDENCIA CORREGIDA (¡SINTAXIS VÁLIDA!)
console.log("Ejemplo con paréntesis:");
console.log((-2) ** 2);    // Output: 4 (correcto)
console.log(-(2 ** 2));    // Output: -4 (operación diferente)

/* 
Regla clave:
- NUNCA uses "-2 ** 2" (sintaxis inválida)
- SIEMPRE usa paréntesis cuando combines unario (-) con **:
    (-a) ** b  -> Base negativa
    -(a ** b)  -> Negativo del resultado
*/

// 3. Cálculo con variables (sin cambios)
let base = 5;
let exponente = 3;
console.log(`${base}^${exponente} = ${base ** exponente}`); // Output: 5^3 = 125

// =============================================
// EJEMPLO ADICIONAL PARA CLARIDAD
// =============================================
console.log("\nDiferencias clave:");
console.log("(-3) ** 2 =", (-3) ** 2);    // (-3)² = 9
console.log("-(3 ** 2) =", -(3 ** 2));    // -(3²) = -9</code></pre>
