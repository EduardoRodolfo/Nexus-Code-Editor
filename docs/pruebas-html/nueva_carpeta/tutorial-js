          case 4: resultadoDiv.innerHTML += "null es un primitivo pero typeof devuelve 'object' (error histórico de JavaScript)"; break;
          case 5: resultadoDiv.innerHTML += "Las funciones son objetos especiales con su propio tipo"; break;
