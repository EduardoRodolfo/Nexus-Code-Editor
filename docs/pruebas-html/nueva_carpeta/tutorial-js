        async function copyCode(button) {
            const container = button.closest('.example');
            const codeElement = container.querySelector('code');
            
            try {
                // Copiar usando la moderna Clipboard API
                await navigator.clipboard.writeText(codeElement.textContent);
                
                // Feedback visual
                const originalText = button.innerHTML;
                button.innerHTML = '✓ Copiado!';
                
                // GUARDAR EL CÓDIGO COPIADO PARA EL EDITOR
                sessionStorage.setItem('copiedCode', codeElement.textContent);
                
                // REDIRIGIR AL EDITOR DESPUÉS DE COPIAR
                setTimeout(() => {
                    window.location.href = 'index.html';
                }, 800);
            } catch (err) {
                console.error('Error al copiar: ', err);
                button.innerHTML = '❌ Error';
                setTimeout(() => {
                    button.innerHTML = '📋 Copiar';
                }, 2000);
            }
        }

