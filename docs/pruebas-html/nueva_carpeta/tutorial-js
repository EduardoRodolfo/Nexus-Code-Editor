            editor.session.setMode("ace/mode/javascript");
            editor.setOptions({
                fontSize: "14px",
                showPrintMargin: false,
                highlightActiveLine: true,
                highlightSelectedWord: true
            });
            editorElement.aceEditor = editor;
        });

        // Función para ejecutar código
        function runCode(editorId, resultId) {
            const editorElement = document.getElementById(editorId);
            const editor = editorElement.aceEditor;
            const code = editor.getValue();
            const resultElement = document.getElementById(resultId);
            const consoleOutput = document.getElementById('consoleOutput');
            
            try {
                // Capturar console.log
                const originalConsoleLog = console.log;
                let logs = [];
                
                console.log = function(...args) {
                    logs.push(args.join(' '));
                    originalConsoleLog.apply(console, args);
                };
                
                // Ejecutar el código
                const execute = new Function(code);
                execute();
                
                // Restaurar console.log
                console.log = originalConsoleLog;
                
                // Mostrar resultados
                if (logs.length &gt; 0) {
                    resultElement.innerHTML = logs.map(log =&gt; 
                        `&lt;div class="result-value"&gt;${log}&lt;/div&gt;`
                    ).join('');
                } else {
                    resultElement.innerHTML = '&lt;div class="result-value"&gt;(El código se ejecutó, pero no se mostraron resultados)&lt;/div&gt;';
                }
                
                // Agregar mensaje a la consola
                const operatorName = editorElement.closest('.operator-card').querySelector('.operator-name').textContent;
                const consoleMessage = document.createElement('div');
                consoleMessage.className = 'console-message result';
                consoleMessage.innerHTML = `▶ &lt;strong&gt;${operatorName}:&lt;/strong&gt; ${logs.join(', ') || 'Ejecución exitosa'}`;
                consoleOutput.appendChild(consoleMessage);
                
            } catch (error) {
                resultElement.innerHTML = `&lt;div class="result-value" style="color:#e74c3c;"&gt;Error: ${error.message}&lt;/div&gt;`;
                
                const operatorName = editorElement.closest('.operator-card').querySelector('.operator-name').textContent;
                const consoleMessage = document.createElement('div');
                consoleMessage.className = 'console-message result';
                consoleMessage.innerHTML = `▶ &lt;strong&gt;Error en ${operatorName}:&lt;/strong&gt; ${error.message}`;
                consoleMessage.style.color = '#e74c3c';
                consoleOutput.appendChild(consoleMessage);
            }
            
            // Hacer scroll al final de la consola
            consoleOutput.scrollTop = consoleOutput.scrollHeight;
        }
    &lt;/script&gt;
&lt;/body&gt;
