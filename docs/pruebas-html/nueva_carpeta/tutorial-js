    &lt;script&gt;
        // Inicializar editores Ace
        document.querySelectorAll('.editor').forEach(editorElement =&gt; {
            const editor = ace.edit(editorElement);
            editor.setTheme("ace/theme/monokai");
            editor.session.setMode("ace/mode/javascript");
            editor.setOptions({
                fontSize: "16px",
                showPrintMargin: false,
                highlightActiveLine: true,
                highlightSelectedWord: true,
                enableBasicAutocompletion: true,
                enableLiveAutocompletion: true
            });
            
            // Guardar referencia al editor en el elemento
            editorElement.aceEditor = editor;
        });

        // Función para ejecutar código
        function runCode(editorId) {
            const editorElement = document.getElementById(editorId);
            const editor = editorElement.aceEditor;
            const code = editor.getValue();
            const resultElement = document.getElementById('result' + editorId.replace('editor', ''));
            const consoleOutput = document.getElementById('consoleOutput');
            
            try {
                // Crear función temporal para ejecutar el código
                const execute = new Function(`
                    try {
                        return eval(${JSON.stringify(code)});
                    } catch (e) {
                        return {
                            success: false,
                            error: e
                        };
                    }
                `);
                
                const executionResult = execute();
                
                if (executionResult &amp;&amp; executionResult.success === false) {
                    throw executionResult.error;
                }
                
                // Obtener el nombre del operador desde el header de la tarjeta
                const card = editorElement.closest('.operator-card');
                const operatorName = card.querySelector('.operator-header').textContent;
                
                // Formatear el resultado
                let formattedResult;
                if (typeof executionResult === 'undefined') {
                    formattedResult = 'undefined';
                } else if (executionResult === null) {
                    formattedResult = 'null';
                } else if (typeof executionResult === 'object') {
                    formattedResult = JSON.stringify(executionResult, null, 2);
                } else if (typeof executionResult === 'string') {
                    formattedResult = `"${executionResult}"`;
                } else {
                    formattedResult = executionResult.toString();
                }
                
                // Mostrar resultado en la tarjeta
                resultElement.textContent = formattedResult;
                resultElement.style.color = '#2ecc71';
                
                // Mostrar en consola
                const consoleMessage = document.createElement('div');
                consoleMessage.className = 'console-message result';
                consoleMessage.innerHTML = `▶ &lt;strong&gt;${operatorName}:&lt;/strong&gt; ${formattedResult}`;
                consoleOutput.appendChild(consoleMessage);
                
            } catch (error) {
                // Obtener el nombre del operador desde el header de la tarjeta
                const card = editorElement.closest('.operator-card');
                const operatorName = card.querySelector('.operator-header').textContent;
                
                resultElement.innerHTML = `&lt;span style="color: #ff5252;"&gt;Error: ${error.message}&lt;/span&gt;`;
                
                const consoleMessage = document.createElement('div');
                consoleMessage.className = 'console-message error';
                consoleMessage.innerHTML = `▶ &lt;strong&gt;Error en ${operatorName}:&lt;/strong&gt; ${error.message}`;
                consoleOutput.appendChild(consoleMessage);
            }
            
            // Hacer scroll al final de la consola
            consoleOutput.scrollTop = consoleOutput.scrollHeight;
        }

        // Ejecutar todos los ejemplos
        document.getElementById('runAllBtn').addEventListener('click', function() {
            // Agregar mensaje a la consola
