<h3 class="example-title">Ejemplos de exponenciación  en JavaScript.</h3>
<pre><code>// 1. Operador básico (**)
let resultado1 = 2 ** 3;  // 2 elevado a 3 (2*2*2)
console.log(resultado1);  // Output: 8

// 2. Función Math.pow() (alternativa clásica)
let resultado2 = Math.pow(4, 2);  // 4 elevado al cuadrado (4*4)
console.log(resultado2);  // Output: 16

// 3. Exponente cero (siempre 1)
let resultado3 = 5 ** 0;  // Cualquier número elevado a 0 es 1
console.log(resultado3);  // Output: 1

// 4. Exponentes negativos (fracciones)
let resultado4 = 3 ** -2;  // Equivale a 1/(3^2) = 1/9
console.log(resultado4);  // Output: 0.111111...

// 5. Exponentes fraccionarios (raíces)
let resultado5 = 16 ** (1/2);  // Raíz cuadrada de 16
console.log(resultado5);  // Output: 4

let resultado6 = 8 ** (1/3);  // Raíz cúbica de 8
console.log(resultado6);  // Output: 2

// 6. Bases decimales
let resultado7 = 2.5 ** 2;  // 2.5 elevado al cuadrado (2.5*2.5)
console.log(resultado7);  // Output: 6.25

// 7. Precedencia de operadores (uso de paréntesis)
let resultado8 = (2 + 3) ** 2;  // Primero suma: 5^2 = 25
let resultado9 = 2 + 3 ** 2;    // Primero exponente: 2 + 9 = 11
console.log(resultado8, resultado9);  // Output: 25 11

// 8. Asignación compuesta (**=)
let numero = 3;
numero **= 2;  // Equivale a: numero = numero ** 2
console.log(numero);  // Output: 9

// 9. Bases negativas (con paréntesis)
let resultado10 = (-2) ** 3;  // (-2)*(-2)*(-2) = -8
let resultado11 = - (2 ** 3); // -(2^3) = -8 (operación diferente)
console.log(resultado10, resultado11);  // Output: -8 -8

// 10. Valores especiales
let resultado12 = Infinity ** 2;  // Infinito al cuadrado
console.log(resultado12);  // Output: Infinity

let resultado13 = NaN ** 2;  // Operación inválida
console.log(resultado13);  // Output: NaN</code></pre>
