<pre><code>function calcularFactorial(n) {
    if (n < 0) return NaN; // NaN = "Not a Number"
    if (n === 0) return 1; // Optimización para caso base
    
    let resultado = 1;
    for (let i = n; i >= 1; i--) {
        resultado *= i;
    }
    return resultado;
}
console.log(calcularFactorial(5));   // 120
console.log(calcularFactorial(0));   // 1
console.log(calcularFactorial(1));   // 1
console.log(calcularFactorial(-1));  // NaN
console.log(calcularFactorial(3.5)); // NaN (opcional)
</code></pre>
